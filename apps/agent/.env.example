# Identidade do Agente
AGENT_NAME=Lucas

# Telegram Bot API (opcional)
BOT_TOKEN=

# Telegram Userbot MTProto (opcional - para responder como conta pessoal)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# WhatsApp Evolution API (opcional)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=lucas

# Memória ai-memory (obrigatório)
AI_MEMORY_URL=http://127.0.0.1:8080

# Personalidade via GitHub (opcional - URL de documento .md privado ou público)
GITHUB_PERSONALITY_URL=
GITHUB_TOKEN=

# 9router Gateway Interno
ROUTER_BASE_URL=http://127.0.0.1:20128/v1
ROUTER_API_KEY=

# Segredo de autenticação HMAC interno Proxy <-> Agent
AGENT_INTERNAL_SECRET=seu_segredo_hmac_aqui

# Porta interna do agente (loopback)
PORT=3717

# Interações autônomas
AUTONOMOUS_INTERACTIONS_ENABLED=true

# Model ranking
MODEL_RANKING=kr/auto-thinking,kr/claude-sonnet-4.5-thinking,kr/deepseek-3.2-thinking

# Cache de quota
QUOTA_RETRY_SEC=120

# Máximo de histórico
MAX_HISTORY=20

# Notion (opcional)
NOTION_TOKEN=
NOTION_DATABASE_ID=
