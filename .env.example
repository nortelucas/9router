# MaxRouter environment contract
# This file reflects actual runtime usage in the current codebase.

# Required
JWT_SECRET=change-me-to-a-long-random-secret
INITIAL_PASSWORD=change-me
DATA_DIR=/var/lib/9router

# --- Persistence -----------------------------------------------------------
# All state (settings, OAuth connections, combos) lives in SQLite under DATA_DIR.
# On ephemeral-filesystem hosts (Railway/Fly) that resets on every deploy unless
# you either (A) mount a persistent volume at DATA_DIR, or (B) use managed cloud
# SQLite via Turso/libSQL below. When these two are set, MaxRouter uses Turso
# automatically (embedded replica, synchronous, syncs to the cloud); if unset or
# unavailable it falls back to local SQLite. Get a free DB at https://turso.tech
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token
# Optional: how often the embedded replica syncs to the cloud (ms, default 15000)
# TURSO_SYNC_INTERVAL_MS=15000

# Recommended runtime variables
PORT=20128
NODE_ENV=production

# Recommended security and ops variables
API_KEY_SECRET=endpoint-proxy-api-key-secret
MACHINE_ID_SALT=endpoint-proxy-salt
ENABLE_REQUEST_LOGS=false
OBSERVABILITY_ENABLED=true
AUTH_COOKIE_SECURE=false
REQUIRE_API_KEY=false

